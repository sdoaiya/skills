{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProjectCard",
  "type": "object",
  "required": [
    "id",
    "name",
    "status",
    "owner",
    "stakeholders",
    "facts",
    "next_actions"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "planning",
        "paused",
        "archived"
      ]
    },
    "owner": {
      "type": "string"
    },
    "stakeholders": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "facts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_updated": {
      "type": "string"
    }
  }
}